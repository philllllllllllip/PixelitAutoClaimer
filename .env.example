# Copy this file to .env and fill in your credentials.
# Use unique variable names to avoid conflicts with Windows environment variables.
PIXELIT_USERNAME="your_username_here"
PIXELIT_PASSWORD="your_password_here"
# Optional: change if the site URL updates.
SITE_URL=https://izumiihd.xyz
# Optional: polling interval in milliseconds when waiting for the daily wheel.
POLL_INTERVAL_MS=30000
# Optional: maximum time in milliseconds to wait before stopping.
MAX_WAIT_MS=21600000
